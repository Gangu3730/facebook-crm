generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Client {
  id               String                 @id @default(uuid())
  companyName      String                 @map("company_name")
  contactPerson    String                 @map("contact_person")
  email            String                 @unique
  phone            String?
  website          String?
  industry         String?
  address          String?                @db.Text
  status           String                 @default("Active")
  packageName      String                 @default("Standard") @map("package_name")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  systemSettings   ClientSetting[]
  fbConnections    FacebookConnection[]
  fbFieldMappings  FacebookFieldMapping[]
  fbForms          FacebookLeadForm[]
  fbPages          FacebookPage[]
  fbWebhookLogs    FacebookWebhookLog[]
  leadActivities   LeadActivity[]
  leadNotes        LeadNote[]
  leadRoutingRules LeadRoutingRule[]
  leads            Lead[]
  notifications    Notification[]
  tasks            Task[]
  users            User[]

  @@map("clients")
}

model User {
  id            String         @id @default(uuid())
  clientId      String?        @map("client_id")
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  role          String
  status        String         @default("Active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  activities    LeadActivity[]
  notes         LeadNote[]
  assignedLeads Lead[]         @relation("AssignedLeads")
  notifications Notification[]
  tasks         Task[]         @relation("AssignedTasks")
  createdTasks  Task[]         @relation("CreatedTasks")
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId], map: "users_client_id_fkey")
  @@map("users")
}

model Lead {
  id                String         @id @default(uuid())
  clientId          String         @map("client_id")
  facebookLeadgenId String?        @unique @map("facebook_leadgen_id")
  facebookPageId    String?        @map("facebook_page_id")
  facebookFormId    String?        @map("facebook_form_id")
  name              String
  phone             String?
  email             String?
  city              String?
  serviceInterest   String?        @map("service_interest")
  message           String?        @db.Text
  source            String         @default("Manual")
  campaignName      String?        @map("campaign_name")
  campaignId        String?        @map("campaign_id")
  adName            String?        @map("ad_name")
  adId              String?        @map("ad_id")
  syncStatus        String         @default("Synced") @map("sync_status")
  status            String         @default("New")
  priority          String         @default("Warm")
  assignedUserId    String?        @map("assigned_to")
  followUpDate      DateTime?      @map("follow_up_date")
  lastContactedAt   DateTime?      @map("last_contacted_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  activities        LeadActivity[]
  notes             LeadNote[]
  assignedUser      User?          @relation("AssignedLeads", fields: [assignedUserId], references: [id])
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@index([clientId])
  @@index([assignedUserId], map: "leads_assigned_to_fkey")
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  leadId    String   @map("lead_id")
  userId    String   @map("user_id")
  note      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([leadId], map: "lead_notes_lead_id_fkey")
  @@index([userId], map: "lead_notes_user_id_fkey")
  @@map("lead_notes")
}

model LeadActivity {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  leadId      String   @map("lead_id")
  userId      String?  @map("user_id")
  type        String
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([leadId], map: "lead_activities_lead_id_fkey")
  @@index([userId], map: "lead_activities_user_id_fkey")
  @@map("lead_activities")
}

model Task {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  leadId         String   @map("lead_id")
  assignedUserId String   @map("assigned_to")
  createdUserId  String   @map("created_by")
  title          String
  description    String?  @db.Text
  dueDate        DateTime @map("due_date")
  status         String   @default("Pending")
  reminderSent   Boolean  @default(false) @map("reminder_sent")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  assignedUser   User     @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: Cascade)
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdUser    User     @relation("CreatedTasks", fields: [createdUserId], references: [id], onDelete: Cascade)
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([assignedUserId], map: "tasks_assigned_to_fkey")
  @@index([createdUserId], map: "tasks_created_by_fkey")
  @@index([leadId], map: "tasks_lead_id_fkey")
  @@map("tasks")
}

model Notification {
  id        String   @id @default(uuid())
  clientId  String?  @map("client_id")
  userId    String   @map("user_id")
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId], map: "notifications_user_id_fkey")
  @@map("notifications")
}

model FacebookConnection {
  id                   String         @id @default(uuid())
  clientId             String         @map("client_id")
  fbUserId             String         @map("fb_user_id")
  fbAccountName        String         @map("fb_account_name")
  accessTokenEncrypted String         @map("access_token_encrypted") @db.Text
  tokenExpiresAt       DateTime?      @map("token_expires_at")
  connectionStatus     String         @default("Active") @map("connection_status")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pages                FacebookPage[]

  @@index([clientId])
  @@map("facebook_connections")
}

model FacebookPage {
  id                       String             @id @default(uuid())
  clientId                 String             @map("client_id")
  facebookConnectionId     String             @map("facebook_connection_id")
  pageId                   String             @map("page_id")
  pageName                 String             @map("page_name")
  pageAccessTokenEncrypted String             @map("page_access_token_encrypted") @db.Text
  status                   String             @default("Active")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  forms                    FacebookLeadForm[]
  client                   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  connection               FacebookConnection @relation(fields: [facebookConnectionId], references: [id], onDelete: Cascade)

  @@unique([clientId, pageId])
  @@index([clientId])
  @@index([facebookConnectionId], map: "facebook_pages_facebook_connection_id_fkey")
  @@map("facebook_pages")
}

model FacebookLeadForm {
  id             String                 @id @default(uuid())
  clientId       String                 @map("client_id")
  facebookPageId String                 @map("facebook_page_id")
  formId         String                 @map("form_id")
  formName       String                 @map("form_name")
  status         String                 @default("Active")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  fieldMappings  FacebookFieldMapping[]
  client         Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  page           FacebookPage           @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)

  @@unique([clientId, formId])
  @@index([clientId])
  @@index([facebookPageId], map: "facebook_lead_forms_facebook_page_id_fkey")
  @@map("facebook_lead_forms")
}

model FacebookFieldMapping {
  id                String           @id @default(uuid())
  clientId          String           @map("client_id")
  formId            String           @map("form_id")
  facebookFieldName String           @map("facebook_field_name")
  crmFieldName      String           @map("crm_field_name")
  createdAt         DateTime         @default(now()) @map("created_at")
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  form              FacebookLeadForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([formId], map: "facebook_field_mappings_form_id_fkey")
  @@map("facebook_field_mappings")
}

model FacebookWebhookLog {
  id           String   @id @default(uuid())
  clientId     String?  @map("client_id")
  pageId       String?  @map("page_id")
  formId       String?  @map("form_id")
  leadgenId    String?  @map("leadgen_id")
  status       String
  errorMessage String?  @map("error_message") @db.Text
  payload      String   @db.LongText
  createdAt    DateTime @default(now()) @map("created_at")
  client       Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("facebook_webhook_logs")
}

model LeadRoutingRule {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  ruleType     String   @default("round_robin") @map("rule_type")
  userIds      String   @map("user_ids") @db.Text
  currentIndex Int      @default(0) @map("current_index")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("lead_routing_rules")
}

model ClientSetting {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, key])
  @@index([clientId])
  @@map("client_settings")
}

model AgencySetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agency_settings")
}
